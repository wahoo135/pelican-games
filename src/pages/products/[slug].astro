---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const statusLabels: Record<string, string> = {
  online: '已上线',
  wip: '研发中',
  planned: '规划中',
};
---

<BaseLayout title={`《${product.data.name}》- 鹈鹕游戏`} description={product.data.tagline}>
    <div class="container product-detail">
        <div class="product-hero">
            <img src={product.data.image} alt={product.data.name} class="product-hero-img" />
            <div class="product-hero-overlay">
                <div class="product-badge-row">
                    <span class={`tag ${product.data.status}`}>{statusLabels[product.data.status]}</span>
                    {product.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
                <h1>《{product.data.name}》</h1>
                {product.data.tagline && <p class="tagline">{product.data.tagline}</p>}
            </div>
        </div>

        <div class="product-info-bar">
            {product.data.price && (
            <div class="info-item">
                <span class="info-label">价格</span>
                <span class="info-value price">{product.data.price}</span>
            </div>
            )}
            {product.data.players && (
            <div class="info-item">
                <span class="info-label">人数</span>
                <span class="info-value">{product.data.players}</span>
            </div>
            )}
            {product.data.duration && (
            <div class="info-item">
                <span class="info-label">时长</span>
                <span class="info-value">{product.data.duration}</span>
            </div>
            )}
        </div>

        <div class="product-actions-bar">
            {product.data.buyLink && (
            <a href={product.data.buyLink} class="btn btn-primary">立即购买</a>
            )}
            {product.data.detailLink && (
            <a href={product.data.detailLink} class="btn btn-secondary">了解更多</a>
            )}
            <a href="/#works" class="btn btn-secondary">返回作品列表</a>
        </div>

        <div class="prose" style="margin-top: 48px;">
            <Content />
        </div>

        <div style="margin-top: 60px; padding-top: 30px; border-top: 1px solid var(--secondary-gray);">
            <a href="/#works" class="btn btn-secondary">← 返回作品列表</a>
        </div>
    </div>
</BaseLayout>

<style>
    .product-detail { padding-top: 100px; max-width: 900px; }
    .product-hero { position: relative; border-radius: 12px; overflow: hidden; margin-bottom: 32px; }
    .product-hero-img { width: 100%; height: 400px; object-fit: cover; display: block; }
    .product-hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 40px 32px 32px; background: linear-gradient(transparent, rgba(15,23,42,0.9)); color: white; }
    .product-hero-overlay h1 { font-size: 32px; font-weight: 400; margin-top: 8px; letter-spacing: 0.05em; }
    .tagline { font-size: 16px; opacity: 0.8; margin-top: 8px; }
    .product-badge-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .tag { padding: 4px 12px; border-radius: 100px; font-size: 12px; background: rgba(255,255,255,0.2); color: white; }
    .tag.online { background: rgba(248,244,238,0.3); color: white; }
    .tag.wip { background: rgba(226,232,240,0.3); color: white; }

    .product-info-bar { display: flex; gap: 32px; padding: 24px 0; border-bottom: 1px solid var(--secondary-gray); margin-bottom: 24px; }
    .info-item { display: flex; flex-direction: column; gap: 4px; }
    .info-label { font-size: 12px; color: var(--text-secondary); letter-spacing: 0.1em; }
    .info-value { font-size: 18px; color: var(--text-primary); }
    .info-value.price { color: var(--primary); font-weight: 500; }

    .product-actions-bar { display: flex; gap: 16px; flex-wrap: wrap; }

    @media (max-width: 768px) {
        .product-hero-img { height: 260px; }
        .product-hero-overlay { padding: 24px 20px 20px; }
        .product-hero-overlay h1 { font-size: 24px; }
        .product-info-bar { gap: 20px; }
    }
</style>
